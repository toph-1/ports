#!/bin/bash

clear

check_cmd() {
command -v "$1" >/dev/null 2>&1
}

echo "🎮 PS5 Network Tester"
echo "====================="

# 1. Internet test

echo -e "\n[1] Internet Test"
if ping -c 1 google.com >/dev/null 2>&1; then
echo "✔ Internet OK"
else
echo "✖ Internet NOT working"
fi

# 2. DNS test

echo -e "\n[2] DNS Test"
if check_cmd nslookup; then
nslookup playstation.com >/dev/null 2>&1 && 
echo "✔ DNS OK" || echo "✖ DNS issue"
else
echo "⚠ nslookup not installed (skipping)"
fi

# 3. Port test (using bash only, no nc)

echo -e "\n[3] PSN Port Test"
HOST="playstation.com"

for PORT in 80 443 3478 3479 3480; do
timeout 2 bash -c "echo > /dev/tcp/$HOST/$PORT" 2>/dev/null && 
echo "✔ Port $PORT open" || 
echo "✖ Port $PORT blocked"
done

# 4. Public IP

echo -e "\n[4] Public IP"
if check_cmd curl; then
curl -s ifconfig.me && echo ""
else
echo "⚠ curl not installed"
fi

echo -e "\n====================="
echo "Done."
